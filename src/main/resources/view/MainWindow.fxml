<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity"
            prefHeight="600.0" prefWidth="400.0"
            style="-fx-background-color: #FFF5E6;"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="orange.MainWindow">
    <children>
        <ScrollPane fx:id="scrollPane"
                    fitToWidth="true"
                    hbarPolicy="NEVER"
                    prefHeight="558.0"
                    prefWidth="400.0"
                    vvalue="1.0"
                    style="-fx-background: #FFF5E6; -fx-background-color: #FFF5E6;"
                    AnchorPane.topAnchor="0.0"
                    AnchorPane.bottomAnchor="50.0"
                    AnchorPane.leftAnchor="0.0"
                    AnchorPane.rightAnchor="0.0">
            <content>
                <VBox fx:id="dialogContainer"
                      prefWidth="388.0"
                      style="-fx-background-color: #FFF5E6; -fx-padding: 10;"
                      spacing="10.0" />
            </content>
        </ScrollPane>

        <TextField fx:id="userInput"
                   onAction="#handleUserInput"
                   promptText="Type a command here..."
                   style="-fx-background-color: white; -fx-background-radius: 20; -fx-border-color: #FF8C00; -fx-border-radius: 20; -fx-border-width: 2; -fx-padding: 10; -fx-font-size: 14px;"
                   AnchorPane.bottomAnchor="5.0"
                   AnchorPane.leftAnchor="10.0"
                   AnchorPane.rightAnchor="90.0" />

        <Button fx:id="sendButton"
                mnemonicParsing="false"
                onAction="#handleUserInput"
                text="Send"
                style="-fx-background-color: #FF8C00; -fx-text-fill: white; -fx-background-radius: 20; -fx-font-size: 14px; -fx-font-weight: bold; -fx-cursor: hand;"
                prefHeight="40.0"
                prefWidth="70.0"
                AnchorPane.bottomAnchor="5.0"
                AnchorPane.rightAnchor="10.0" />
    </children>
</AnchorPane>